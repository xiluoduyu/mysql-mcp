# HTTP bind address
MCP_BIND_ADDR=127.0.0.1:9090

# MCP Bearer token (required)
MCP_BEARER_TOKEN=replace-with-strong-token

# MySQL sources (required):
# - single source (unnamed, auto as source=default):
#   MYSQL_DSNS=user:password@tcp(127.0.0.1:3306)/dbname?parseTime=true&loc=Local
# - multiple sources (named):
#   MYSQL_DSNS=core=user:password@tcp(127.0.0.1:3306)/core?parseTime=true&loc=Local;audit=user:password@tcp(127.0.0.1:3306)/audit?parseTime=true&loc=Local
MYSQL_DSNS=user:password@tcp(127.0.0.1:3306)/dbname?parseTime=true&loc=Local

# Approval client mode: http | local_desktop
APPROVAL_CLIENT_MODE=local_desktop

# External approval service (required when APPROVAL_CLIENT_MODE=http)
APPROVAL_BASE_URL=http://127.0.0.1:8088
APPROVAL_SUBMIT_PATH=/approvals
APPROVAL_STATUS_PATH_TEMPLATE=/approvals/{id}

# Callback HMAC secret (required)
APPROVAL_CALLBACK_SECRET=replace-with-hmac-secret

# Runtime tuning
APPROVAL_POLL_INTERVAL=3s
APPROVAL_TIMEOUT=30m
STATE_SQLITE_PATH=./data/state.db
MAX_LIMIT=200

# Query result masking
# Default keyword-based masking applies to field names containing:
# password, token, secret, key
# You can extend/override via env:
# MASK_FIELD_KEYWORDS=password,token,secret,key,credential
# MASK_FIELDS=api_key,users.phone,orders.bank_card
# MASK_JSON_FIELDS=users.profile,orders.payload
MASK_FIELD_KEYWORDS=
MASK_FIELDS=
MASK_JSON_FIELDS=
